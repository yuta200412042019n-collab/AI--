# -*- coding: utf-8 -*-
"""
Gemini-Brain Discord Bot
- discord.py 2.x + Google Generative AI
- 全 Intents 明示宣言済み
- チャンネルごとに直近20件の会話履歴を保持
"""

import os
import sys
import traceback
from collections import defaultdict, deque

import discord
from discord.ext import commands
from dotenv import load_dotenv

import google.generativeai as genai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  環境変数の読み込み
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
load_dotenv()

DISCORD_TOKEN  = os.getenv("DISCORD_TOKEN", "")
GEMINI_API_KEY = os.getenv("GEMINI_API_KEY", "")

if not DISCORD_TOKEN:
    print("[FATAL] DISCORD_TOKEN が設定されていません。")
    sys.exit(1)
if not GEMINI_API_KEY:
    print("[FATAL] GEMINI_API_KEY が設定されていません。")
    sys.exit(1)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Gemini セットアップ
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
genai.configure(api_key=GEMINI_API_KEY)

SYSTEM_INSTRUCTION = (
    "あなたは Discord サーバーに常駐する優秀なAIアシスタントです。\n"
    "日本語で簡潔かつ親切に回答してください。\n"
    "コードブロックやマークダウンを適切に使い、読みやすい返答を心がけてください。\n"
    "Discordのメッセージ上限(2000文字)を意識し、長くなりすぎないようにしてください。"
)

# Gemini モデル（gemini-2.0-flash を優先、なければ 1.5-flash にフォールバック）
MODEL_CANDIDATES = ["gemini-2.0-flash", "gemini-1.5-flash", "gemini-pro"]
model = None
for model_name in MODEL_CANDIDATES:
    try:
        model = genai.GenerativeModel(
            model_name=model_name,
            system_instruction=SYSTEM_INSTRUCTION,
            generation_config=genai.GenerationConfig(
                max_output_tokens=1500,
                temperature=0.7,
            ),
        )
        # 疎通テスト
        model.generate_content("ping")
        print(f"[Gemini] モデル '{model_name}' を使用します。")
        break
    except Exception:
        model = None
        continue

if model is None:
    print("[FATAL] 利用可能な Gemini モデルが見つかりません。APIキーを確認してください。")
    sys.exit(1)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  会話履歴（チャンネルごとに20件保持）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MAX_HISTORY = 20
channel_histories: dict[int, deque] = defaultdict(lambda: deque(maxlen=MAX_HISTORY))

def build_prompt(channel_id: int, user_name: str, user_message: str) -> str:
    """会話履歴を含むプロンプトを構築"""
    history = channel_histories[channel_id]
    lines = []
    for role, name, text in history:
        if role == "user":
            lines.append(f"{name}: {text}")
        else:
            lines.append(f"Bot: {text}")
    lines.append(f"{user_name}: {user_message}")
    return "\n".join(lines)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Discord Bot セットアップ
#  ★ Intents 完全宣言 — ここが権限エラー防止の核心
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
intents = discord.Intents.default()
intents.message_content = True   # ← Developer Portal で有効化必須
intents.members = True
intents.presences = False        # 不要なので明示的に OFF

bot = commands.Bot(
    command_prefix="!",
    intents=intents,
    help_command=None,
)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  イベントハンドラ
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
@bot.event
async def on_ready():
    print("=" * 50)
    print(f"  Bot ログイン成功！")
    print(f"  ユーザー名 : {bot.user.name}")
    print(f"  Bot ID     : {bot.user.id}")
    print(f"  サーバー数 : {len(bot.guilds)}")
    print("=" * 50)
    print()
    print("【使い方】")
    print("  Discordの任意のチャンネルで Bot にメンション(@Bot名)するか、")
    print("  DMを送るとGeminiが返答します。")
    print("  !clear  → そのチャンネルの会話履歴をリセット")
    print("  !ping   → 生存確認")
    print()
    await bot.change_presence(
        activity=discord.Activity(
            type=discord.ActivityType.listening,
            name="メンションを待機中...",
        )
    )

@bot.event
async def on_message(message: discord.Message):
    # Bot 自身のメッセージは無視
    if message.author.bot:
        return

    # コマンド処理を先に通す
    await bot.process_commands(message)

    # メンションされたか DM か判定
    is_mentioned = bot.user in message.mentions
    is_dm = isinstance(message.channel, discord.DMChannel)

    if not is_mentioned and not is_dm:
        return

    # メンション文字列を除去
    user_text = message.content
    for mention in message.mentions:
        user_text = user_text.replace(f"<@{mention.id}>", "")
        user_text = user_text.replace(f"<@!{mention.id}>", "")
    user_text = user_text.strip()

    if not user_text:
        await message.reply("何か質問を入力してください！", mention_author=False)
        return

    # Typing 表示
    async with message.channel.typing():
        try:
            prompt = build_prompt(
                message.channel.id,
                message.author.display_name,
                user_text,
            )
            response = model.generate_content(prompt)

            if response and response.text:
                reply_text = response.text
            else:
                # safety block 等
                reply_text = "⚠️ 回答を生成できませんでした（安全フィルターに該当した可能性があります）。"

        except Exception as e:
            traceback.print_exc()
            reply_text = f"⚠️ Gemini API エラー: `{type(e).__name__}: {e}`"

    # 履歴に追加
    channel_histories[message.channel.id].append(
        ("user", message.author.display_name, user_text)
    )
    channel_histories[message.channel.id].append(
        ("assistant", "Bot", reply_text[:500])  # 履歴は500文字まで
    )

    # Discord の 2000 文字制限対策：分割送信
    for i in range(0, len(reply_text), 1990):
        chunk = reply_text[i : i + 1990]
        if i == 0:
            await message.reply(chunk, mention_author=False)
        else:
            await message.channel.send(chunk)


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  コマンド
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
@bot.command(name="ping")
async def ping_cmd(ctx: commands.Context):
    """生存確認"""
    latency_ms = round(bot.latency * 1000)
    await ctx.send(f"🏓 Pong!  (レイテンシ: {latency_ms}ms)")

@bot.command(name="clear")
async def clear_cmd(ctx: commands.Context):
    """このチャンネルの会話履歴をリセット"""
    channel_histories[ctx.channel.id].clear()
    await ctx.send("🗑️ このチャンネルの会話履歴をリセットしました。")

@bot.command(name="help")
async def help_cmd(ctx: commands.Context):
    """ヘルプを表示"""
    embed = discord.Embed(
        title="📖 Gemini Bot ヘルプ",
        color=discord.Color.blue(),
    )
    embed.add_field(
        name="💬 会話する",
        value="Bot を @メンション して話しかけるか、DM を送ってください。",
        inline=False,
    )
    embed.add_field(name="!ping",  value="生存確認",         inline=True)
    embed.add_field(name="!clear", value="会話履歴リセット", inline=True)
    embed.add_field(name="!help",  value="このヘルプを表示", inline=True)
    await ctx.send(embed=embed)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  起動
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
if __name__ == "__main__":
    print("[Bot] 起動中...")
    try:
        bot.run(DISCORD_TOKEN, log_level=20)  # 20 = INFO
    except discord.LoginFailure:
        print()
        print("[FATAL] Discord ログイン失敗！以下を確認してください：")
        print("  1. DISCORD_TOKEN が正しいか")
        print("  2. Developer Portal > Bot > 'MESSAGE CONTENT INTENT' が ON か")
        print("  3. Developer Portal > Bot > 'SERVER MEMBERS INTENT' が ON か")
        sys.exit(1)
    except Exception as e:
        print(f"[FATAL] 予期しないエラー: {e}")
        traceback.print_exc()
        sys.exit(1)
'@

